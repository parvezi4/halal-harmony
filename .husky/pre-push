#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"
set -e

# VS Code/Git hook shells on Windows may not include NVM's Node path.
if ! command -v npm >/dev/null 2>&1; then
	if [ -s "$HOME/.nvm/nvm.sh" ]; then
		. "$HOME/.nvm/nvm.sh"
		nvm use --silent >/dev/null 2>&1 || true
	fi
fi

if ! command -v npm >/dev/null 2>&1; then
	echo "husky pre-push: npm not found in PATH"
	echo "Install Node.js or ensure your Node/NPM bin directory is on PATH for Git hooks."
	exit 127
fi

# Run API tests
echo "Running API tests..."
npm run test:api || exit 1

# Run linter
echo "Running linter..."
npm run lint || exit 1

# Run type check
echo "Running type check..."
npm run typecheck || exit 1

echo "✅ All pre-push checks passed!"
