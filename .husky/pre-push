#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"
set -e

# VS Code/Git hook shells on Windows may not include NVM's Node path.
if ! command -v npm >/dev/null 2>&1; then
	if [ -s "$HOME/.nvm/nvm.sh" ]; then
		. "$HOME/.nvm/nvm.sh"
		nvm use --silent >/dev/null 2>&1 || true
	fi
fi

if ! command -v npm >/dev/null 2>&1; then
	echo "husky pre-push: npm not found in PATH"
	echo "Install Node.js or ensure your Node/NPM bin directory is on PATH for Git hooks."
	exit 127
fi

# Run independent checks in parallel to reduce push time.
echo "Running pre-push checks in parallel (typecheck + API tests)..."
npm run typecheck &
TYPECHECK_PID=$!

npm run test:api &
API_TESTS_PID=$!

FAIL=0

wait "$TYPECHECK_PID" || FAIL=1
wait "$API_TESTS_PID" || FAIL=1

if [ "$FAIL" -ne 0 ]; then
	echo "❌ Pre-push checks failed."
	exit 1
fi

echo "✅ All pre-push checks passed!"
