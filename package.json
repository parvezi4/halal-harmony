{
  "name": "halal-harmony",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check:route-root": "node scripts/enforce-src-app-only.mjs",
    "cleanup:legacy-app": "node scripts/cleanup-legacy-app.mjs",
    "predev": "npm run check:route-root",
    "prebuild": "npm run check:route-root",
    "prestart": "npm run check:route-root",
    "prelint": "npm run check:route-root",
    "pretest": "npm run check:route-root",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "eslint .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:api": "jest --testPathPattern=tests/api",
    "typecheck": "tsc --noEmit",
    "precommit:staged": "lint-staged",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "prepare": "husky"
  },
  "dependencies": {
    "@auth/core": "0.34.3",
    "@auth/prisma-adapter": "^2.11.1",
    "@headlessui/react": "^2.2.0",
    "@heroicons/react": "^2.1.5",
    "@hookform/resolvers": "^5.2.2",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.0",
    "next": "^15.5.12",
    "next-auth": "^4.24.13",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.71.2",
    "stripe": "^16.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@next/eslint-plugin-next": "^16.1.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.12.0",
    "eslint-config-next": "15.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "lint-staged": "^16.3.3",
    "postcss": "^8.4.48",
    "prisma": "^6.0.0",
    "tailwindcss": "^3.4.15",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.56.1"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --cache --max-warnings=0 --fix"
    ]
  }
}
