#
# Stripe configuration (example values)
# Copy this file to `.env.local` (for local dev) or configure the same
# variables in your hosting provider (e.g. Vercel).
#

########################
# Core app config
########################

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=laoJvKRg0^VGuQ3@A6AEGTb^hcM@S@oz

# PostgreSQL connection string (Supabase or other Postgres)
DATABASE_URL=postgresql://user:password@localhost:5432/halal_harmony


########################
# Stripe API keys (TEST)
########################

# Secret API key for Stripe (TEST mode only by default).
# Must start with "sk_test_...".
STRIPE_SECRET_KEY=sk_test_your_test_secret_key_here

# Publishable key for Stripe (TEST mode)
STRIPE_PUBLISHABLE_KEY=pk_test_your_test_publishable_key_here

# Webhook signing secret for Stripe (TEST mode)
STRIPE_WEBHOOK_SECRET=whsec_your_test_webhook_secret_here

########################################
# Safety switch for LIVE mode
########################################

# Leave this as "false" (or unset) while developing and testing so that
# the app refuses to start if you accidentally paste a live secret key.
# When you are truly ready for production and have configured live keys
# and prices in Stripe, set this to "true" in your production environment.
STRIPE_ALLOW_LIVE=false


########################################
# Stripe price IDs for Premium (USD)
# Base price: $20 / month
########################################

# Premium Monthly (USD $20 / month, interval: 1 month)
STRIPE_PRICE_PREMIUM_MONTHLY=price_premium_monthly_usd_20

# Premium Quarterly (USD ~$54 / 3 months, ≈ $18/month)
STRIPE_PRICE_PREMIUM_QUARTERLY=price_premium_quarterly_usd_54

# Premium Semiannual (USD ~$96 / 6 months, ≈ $16/month)
STRIPE_PRICE_PREMIUM_SEMIANNUAL=price_premium_semiannual_usd_96

# Premium Annual (USD ~$168 / year, ≈ $14/month)
STRIPE_PRICE_PREMIUM_ANNUAL=price_premium_annual_usd_168

